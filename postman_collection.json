{
  "info": {
    "name": "Multi-Agent Cooking Assistant",
    "description": "API collection for the Multi-Agent Cooking Assistant. Set the `base_url` variable to switch between local and deployed environments.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health",
        "description": "Liveness probe. Returns {\"status\": \"ok\"} with HTTP 200."
      },
      "response": [
        {
          "name": "200 OK",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\"status\": \"ok\"}"
        }
      ]
    },
    {
      "name": "Chef Path — Cook Pasta",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/query",
        "description": "Recipe request. Intent agent classifies as `chef_agent` and returns a structured recipe with ingredients, steps, and tips.",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"I want to cook pasta\"\n}",
          "options": { "raw": { "language": "json" } }
        }
      },
      "response": [
        {
          "name": "200 OK — chef_agent",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"intent\": \"chef_agent\",\n  \"data\": {\n    \"dish_name\": \"Pasta\",\n    \"ingredients\": [\n      \"2 cups all-purpose flour\",\n      \"3 large eggs\",\n      \"1/2 teaspoon salt\",\n      \"1 tablespoon olive oil\"\n    ],\n    \"steps\": [\n      \"Step 1: Combine flour and salt in a large bowl.\",\n      \"Step 2: Make a well and crack eggs into the center.\",\n      \"Step 3: Mix and knead dough for 8-10 minutes.\",\n      \"Step 4: Rest dough for 30 minutes, then roll and cut.\",\n      \"Step 5: Cook in boiling salted water for 2-4 minutes.\"\n    ],\n    \"tips\": [\n      \"Knead well for a smooth texture.\",\n      \"Add water if dough is too dry.\"\n    ],\n    \"video_links\": []\n  }\n}"
        }
      ]
    },
    {
      "name": "Grocer Path — Buy Butter Chicken Ingredients",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/query",
        "description": "Shopping request. Intent agent classifies as `grocer_agent`. LLM extracts ingredients for butter chicken, pricing service fetches mock prices concurrently across stores.",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"Buy ingredients for butter chicken\"\n}",
          "options": { "raw": { "language": "json" } }
        }
      },
      "response": [
        {
          "name": "200 OK — grocer_agent",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"intent\": \"grocer_agent\",\n  \"data\": {\n    \"items\": [\n      { \"name\": \"chicken\", \"price\": 5.99, \"store\": \"Walmart\" },\n      { \"name\": \"butter\", \"price\": 3.49, \"store\": \"Walmart\" },\n      { \"name\": \"cream\", \"price\": 2.99, \"store\": \"Generic Store\" },\n      { \"name\": \"tomato puree\", \"price\": 0.89, \"store\": \"Walmart\" },\n      { \"name\": \"onion\", \"price\": 0.59, \"store\": \"Walmart\" },\n      { \"name\": \"garlic\", \"price\": 0.79, \"store\": \"Walmart\" }\n    ],\n    \"total_cost\": 14.74,\n    \"store_breakdown\": {\n      \"Walmart\": [\n        { \"name\": \"chicken\", \"price\": 5.99, \"store\": \"Walmart\" },\n        { \"name\": \"butter\", \"price\": 3.49, \"store\": \"Walmart\" },\n        { \"name\": \"tomato puree\", \"price\": 0.89, \"store\": \"Walmart\" },\n        { \"name\": \"onion\", \"price\": 0.59, \"store\": \"Walmart\" },\n        { \"name\": \"garlic\", \"price\": 0.79, \"store\": \"Walmart\" }\n      ],\n      \"Generic Store\": [\n        { \"name\": \"cream\", \"price\": 2.99, \"store\": \"Generic Store\" }\n      ]\n    }\n  }\n}"
        }
      ]
    },
    {
      "name": "Ranking — Budget (Price Priority)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/query",
        "description": "Store ranking request with a clear price signal ('cheapest'). Rule-based detection kicks in (no LLM call for preferences). Walmart should rank #1 — lowest subtotal and free delivery.",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"Which store is cheapest for pasta and chicken?\"\n}",
          "options": { "raw": { "language": "json" } }
        }
      },
      "response": [
        {
          "name": "200 OK — ranking_agent (budget)",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"intent\": \"ranking_agent\",\n  \"data\": {\n    \"stores\": [\n      { \"name\": \"Walmart\",      \"total_cost\": 7.48,  \"delivery_time_mins\": 120, \"score\": 0.923 },\n      { \"name\": \"Trader Joe's\", \"total_cost\": 12.97, \"delivery_time_mins\": 240, \"score\": 0.496 },\n      { \"name\": \"Whole Foods\",  \"total_cost\": 21.93, \"delivery_time_mins\": 45,  \"score\": 0.2 }\n    ],\n    \"best_store\": \"Walmart\"\n  }\n}"
        }
      ]
    },
    {
      "name": "Ranking — Fast Delivery Priority",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/query",
        "description": "Store ranking request with a clear speed signal ('fast', 'tonight'). Rule-based detection assigns delivery_weight=0.8. Whole Foods ranks #1 — 45-minute express delivery despite higher cost.",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"I need pasta and chicken fast tonight, which store should I order from?\"\n}",
          "options": { "raw": { "language": "json" } }
        }
      },
      "response": [
        {
          "name": "200 OK — ranking_agent (fast delivery)",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"intent\": \"ranking_agent\",\n  \"data\": {\n    \"stores\": [\n      { \"name\": \"Whole Foods\",  \"total_cost\": 21.93, \"delivery_time_mins\": 45,  \"score\": 0.8 },\n      { \"name\": \"Walmart\",      \"total_cost\": 7.48,  \"delivery_time_mins\": 120, \"score\": 0.692 },\n      { \"name\": \"Trader Joe's\", \"total_cost\": 12.97, \"delivery_time_mins\": 240, \"score\": 0.124 }\n    ],\n    \"best_store\": \"Whole Foods\"\n  }\n}"
        }
      ]
    },
    {
      "name": "Ranking — Balanced / Ambiguous (LLM Fallback)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/query",
        "description": "Ambiguous query with no clear price or delivery keywords. Rule-based detection returns None, triggering a single LLM call to extract weights. Weights default to ~0.5/0.5 — Walmart still wins on combined score.",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"Best place to buy lasagna ingredients\"\n}",
          "options": { "raw": { "language": "json" } }
        }
      },
      "response": [
        {
          "name": "200 OK — ranking_agent (balanced)",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"intent\": \"ranking_agent\",\n  \"data\": {\n    \"stores\": [\n      { \"name\": \"Walmart\",      \"total_cost\": 9.24,  \"delivery_time_mins\": 120, \"score\": 0.808 },\n      { \"name\": \"Trader Joe's\", \"total_cost\": 14.72, \"delivery_time_mins\": 240, \"score\": 0.31 },\n      { \"name\": \"Whole Foods\",  \"total_cost\": 31.87, \"delivery_time_mins\": 45,  \"score\": 0.5 }\n    ],\n    \"best_store\": \"Walmart\"\n  }\n}"
        }
      ]
    },
    {
      "name": "Validation Error — Empty Query",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/query",
        "description": "Sends a whitespace-only query. Pydantic validator rejects it before any LLM call. Expect HTTP 422.",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"   \"\n}",
          "options": { "raw": { "language": "json" } }
        }
      },
      "response": [
        {
          "name": "422 Unprocessable Entity",
          "status": "Unprocessable Entity",
          "code": 422,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"detail\": [\n    { \"msg\": \"Value error, query must not be empty or whitespace\" }\n  ]\n}"
        }
      ]
    }
  ]
}
